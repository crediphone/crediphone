{
  // CREDIPHONE ERP — Cloudflare Workers deployment
  // Adapter: @opennextjs/cloudflare (OpenNext)
  // Docs: https://developers.cloudflare.com/workers/framework-guides/web-apps/nextjs/

  "name": "crediphone",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // Minificación — DESHABILITADA: Next.js 16 RSC ya viene optimizado por opennextjs/cloudflare;
  // double-minify de wrangler renombra variables en bootstrap scripts → ReferenceError: r is not defined
  "minify": false,

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  // Cloudflare R2 — Storage de imágenes (productos y reparaciones)
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "crediphone-storage"
    }
  ],

  // Variables de entorno — configurar en Cloudflare Dashboard > Workers & Pages > crediphone > Settings > Variables
  // NEXT_PUBLIC_SUPABASE_URL
  // NEXT_PUBLIC_SUPABASE_ANON_KEY
  // SUPABASE_SERVICE_ROLE_KEY
  // PAYJOY_API_KEY (si aplica)
  // PAYJOY_WEBHOOK_SECRET (si aplica)
  // NEXT_PUBLIC_APP_URL = https://crediphone.com.mx
  //
  // R2 Storage (REQUERIDO para fotos):
  // NEXT_PUBLIC_R2_PUBLIC_URL = https://pub-XXXX.r2.dev
  //   → Habilitar en: Cloudflare Dashboard > R2 > crediphone-storage > Settings > Public Access
  //   → O usar dominio propio: https://storage.crediphone.com.mx
  //
  // SECURITY — Secrets (agregar en Cloudflare Dashboard > Settings > Secrets, NO en vars):
  // WA_ENCRYPTION_KEY = <base64 de 32 bytes> — generado con: openssl rand -base64 32
  //   → Cifra wa_access_token en la BD. Sin esta key los tokens se guardan en texto plano (fallback).

  // Variables de entorno (plain text — no sensibles)
  "vars": {
    "NEXT_PUBLIC_SUPABASE_URL": "https://ihvjjfsefnvcrczrcmhp.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "sb_publishable_L_zptfavpg_jOx9Mv7uZHQ_ehtvm7iR",
    "NEXT_PUBLIC_R2_PUBLIC_URL": "https://pub-89451411d31c49d9959b166475cda47a.r2.dev",
    "NEXT_PUBLIC_APP_URL": "https://crediphone.com.mx",
    "NEXT_PUBLIC_BASE_URL": "https://crediphone.com.mx",
    "PAYJOY_ENABLED": "true",
    "PAYJOY_BASE_URL": "https://partner.payjoy.com/v1",
    "PAYJOY_AUTO_SYNC": "true",
    "VAPID_PUBLIC_KEY": "BKm53EANbQsh3D4nVroBm8GNZmuVcUPW4qOTn2-BPi_P1D6e3GHcT-iJD_lJ239v0OLxwqiwBOn5vs-bJ0Oq2xY",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY": "BKm53EANbQsh3D4nVroBm8GNZmuVcUPW4qOTn2-BPi_P1D6e3GHcT-iJD_lJ239v0OLxwqiwBOn5vs-bJ0Oq2xY",
    "VAPID_EMAIL": "mailto:admin@crediphone.mx",
    "NEXT_PUBLIC_WHATSAPP_SOPORTE": "526181245391"
  },

  "observability": {
    "enabled": true
  }
}
